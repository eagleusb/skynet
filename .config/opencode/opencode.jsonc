{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  // NOTE: model
  "model": "zai-coding-plan/glm-5.1",
  "small_model": "zai-coding-plan/glm-5-turbo",
  "default_agent": "plan",
  // NOTE: merged with AGENTS.md, support https://
  "instructions": ["CONTRIBUTING.md", "docs/*.md"],

  // NOTE: permissions (default allow)
  "permission": {
  	"read": "allow",
  	"edit": "allow",
  	"grep": "allow",
  	"glob": "allow",
  	"list": "allow",
  	"lsp": "allow",
  	"webfetch": "allow",
  	"bash": "ask",
  },

  // NOTE: local models
  "disabled_providers": ["openai"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "local",
      "options": {
        "baseURL": "http://localhost:11434/v1",
      },
      "models": {
        "ministral-3:3b-instruct-2512-q4_K_M": {
          "name": "ministral3",
        },
      },
    },
  },

  // NOTE: MCP
  "mcp": {
    "godoc": {
          "type": "local",
          "command": [
            "godoc-mcp",
            "-transport=stdio"
          ],
          "environment": {},
        },
    "gopls": {
          "type": "local",
          "command": [
            "gopls",
            "mcp"
          ],
          "environment": {},
        },
    "web-search-prime": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}",
      },
    },
    "web-reader": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer {env:ZAI_API_KEY}",
      },
    },
  },
}
